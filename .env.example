# Leave blank in local development to use Vite's /api proxy.
# Set this to the deployed FastAPI origin for a static frontend deployment.
VITE_API_BASE_URL=

# Optional local proxy override.
VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Comma-separated browser origins accepted by FastAPI.
TRUTHQUEST_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
